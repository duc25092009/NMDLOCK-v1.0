<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    tools:context=".feature.splash.SplashActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp">

        <!-- Logo -->
        <TextView
            android:id="@+id/splash_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NMDLock"
            android:textColor="#6C5CE7"
            android:textSize="42sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="1.0"
            android:textColor="#A29BFE"
            android:textSize="16sp"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Tối ưu thiết bị • Nâng tầm trải nghiệm"
            android:textColor="#888888"
            android:textSize="13sp" />

        <ProgressBar
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="48dp"
            android:indeterminateTint="#6C5CE7" />

        <TextView
            android:id="@+id/splash_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Đang khởi tạo hệ thống…"
            android:textColor="#888888"
            android:textSize="13sp" />

    </LinearLayout>

</FrameLayout>
