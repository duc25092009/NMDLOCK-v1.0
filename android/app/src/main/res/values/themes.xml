<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.NMDLock" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/surface_dark</item>
    </style>

    <!-- Splash screen theme - fix for androidx.core:core-splashscreen -->
    <style name="Theme.SplashScreen" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- NMDLock Splash theme -->
    <style name="Theme.NMDLock.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/surface_dark</item>
        <item name="postSplashScreenTheme">@style/Theme.NMDLock</item>
    </style>
</resources>
